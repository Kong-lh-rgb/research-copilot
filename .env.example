# ── LLM 服务 ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus-2026-02-15

# ── 邮件发送（可选，发送报告功能） ──────────────────────────────────────────────
SENDER_EMAIL=your_email@163.com
SENDER_PASSWORD=your_smtp_password

# ── MCP 服务器密钥 ─────────────────────────────────────────────────────────────
AMAP_MAPS_API_KEY=your_amap_api_key_here

# ── MCP 服务器本机路径（跨机器时修改此处，留空则自动从 PATH 寻找）─────────────────
# UV_BIN=/home/user/.local/bin/uv
# NPX_BIN=/usr/local/bin/npx
# WEATHER_MCP_DIR=/path/to/your/MCP/weather
